# ── Local Development (SQLite) ──────────────────────────────────
# Default: SQLite (no setup needed)
DATABASE_URL=sqlite:///grid_sites.db
API_BASE_URL=http://localhost:8000

# ── Production (PostgreSQL) ─────────────────────────────────────
# Uncomment and fill in for PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/grid_dashboard
# API_BASE_URL=http://your-production-host:8000
